        tInfiniteTower.TextColor3 = infinite_tower_enabled and currentTheme.Acc or currentTheme.Text

-- BOSS FARM LOGIC
        if boss_farming_enabled then
            if not boss_target_part or not boss_target_part.Parent then
                boss_target_part = nil
                local dMax = math.huge
                for _, island in ipairs(islandPaths) do
                    local success, mobs = pcall(function() return island:GetChildren() end)
                    if success and mobs then
                        for _, mob in ipairs(mobs) do
                            if mob:IsA("Model") and selected_boss_data and string.find(mob.Name, selected_boss_data.Name) then
                                local mHrp = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChildWhichIsA("BasePart")
                                local hum = mob:FindFirstChildOfClass("Humanoid")
                                if mHrp and hum and hum.Health > 0 then
                                    local d = (hrp.Position - mHrp.Position).Magnitude
                                    if d < dMax then
                                        dMax = d
                                        boss_target_part = mHrp
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if boss_target_part and boss_target_part.Parent then
                local hum = boss_target_part.Parent:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then
                    boss_target_part = nil
                else
                    local offset = Vector3.new(0, farm_distance, 0)
                    if farm_method == "Below" then
                        offset = Vector3.new(0, -farm_distance, 0)
                    elseif farm_method == "Behind" then
                        offset = boss_target_part.CFrame.LookVector * -farm_distance
                    end
                    hrp.CFrame = CFrame.lookAt(boss_target_part.Position + offset, boss_target_part.Position)
                    hrp.Velocity = Vector3.zero
                end
            end
            return
        end

        
        -- INFINITE TOWER FARM LOGIC
        if infinite_tower_enabled then
            if not infinite_tower_target_part or not infinite_tower_target_part.Parent then
                infinite_tower_target_part = nil
                local dMax = math.huge

                local towerFolder = Workspace:FindFirstChild("Infinite Tower")
                if towerFolder then
                    local runtimeEnemies = towerFolder:FindFirstChild("RuntimeEnemies")
                    if runtimeEnemies then
                        for _, mob in ipairs(runtimeEnemies:GetChildren()) do
                            if mob:IsA("Model") then
                                local mHrp = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChildWhichIsA("BasePart")
                                local hum = mob:FindFirstChildOfClass("Humanoid")
                                if mHrp and hum and hum.Health > 0 then
                                    -- Si hay enemigo seleccionado, buscar solo ese
                                    if selected_tower_enemy and mob.Name == selected_tower_enemy.Name then
                                        local d = (hrp.Position - mHrp.Position).Magnitude
                                        if d < dMax then
                                            dMax = d
                                            infinite_tower_target_part = mHrp
                                        end
                                    elseif not selected_tower_enemy then
                                        -- Si no hay seleccionado, buscar el más cercano
                                        local d = (hrp.Position - mHrp.Position).Magnitude
                                        if d < dMax then
                                            dMax = d
                                            infinite_tower_target_part = mHrp
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if infinite_tower_target_part and infinite_tower_target_part.Parent then
                local hum = infinite_tower_target_part.Parent:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then
                    infinite_tower_target_part = nil
                else
                    -- Usa las variables SEPARADAS de Infinite Tower
                    local offset = Vector3.new(0, infinite_tower_farm_distance, 0)
                    if infinite_tower_farm_method == "Below" then
                        offset = Vector3.new(0, -infinite_tower_farm_distance, 0)
                    elseif infinite_tower_farm_method == "Behind" then
                        offset = infinite_tower_target_part.CFrame.LookVector * -infinite_tower_farm_distance
                    end
                    local targetPos = infinite_tower_target_part.Position + offset
                    hrp.CFrame = CFrame.lookAt(targetPos, infinite_tower_target_part.Position)
                    hrp.Velocity = Vector3.zero
                end
            end

            -- Actualizar texto del toggle
            tInfiniteTower.Text = "AUTO INFINITE TOWER: " .. (infinite_tower_enabled and "ON" or "OFF") .. " ["..key_infinite_tower.Name.."]"
            tInfiniteTower.TextColor3 = infinite_tower_enabled and currentTheme.Acc or currentTheme.Text

            return
        end

if not is_f then return end

        -- NORMAL FARM LOGIC
        if not target_part or not target_part.Parent then
            target_part = nil
            local dMax = math.huge
            for _, island in ipairs(islandPaths) do
                local success, mobs = pcall(function() return island:GetChildren() end)
                if success and mobs then
                    for _, mob in ipairs(mobs) do
                        if mob:IsA("Model") and (nearest_farming_enabled or (farming_enabled and selected_mob_data and string.find(mob.Name, selected_mob_data.Name))) then
                            local mHrp = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChildWhichIsA("BasePart")
                            local hum = mob:FindFirstChildOfClass("Humanoid")
                            if mHrp and hum and hum.Health > 0 then
                                local d = (hrp.Position - mHrp.Position).Magnitude
                                if d < dMax then
                                    dMax = d
                                    target_part = mHrp
                                end
                            end
                        end
                    end
                end
            end
        end

        if target_part and target_part.Parent then
            local hum = target_part.Parent:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then
                target_part = nil
                return
            end
            local offset = Vector3.new(0, farm_distance, 0)
            if farm_method == "Below" then
                offset = Vector3.new(0, -farm_distance, 0)
            elseif farm_method == "Behind" then
                offset = target_part.CFrame.LookVector * -farm_distance
            end
            local targetPos = target_part.Position + offset
            hrp.CFrame = CFrame.lookAt(targetPos, target_part.Position)
            hrp.Velocity = Vector3.zero
        end
    end)

    -- ================= CONTROLES =================
    connect(closeBtn.MouseButton1Click, function()
        is_script_active = false
        farming_enabled = false
        nearest_farming_enabled = false
        boss_farming_enabled = false
        autoclick_enabled = false
        auto_abilities_enabled = false
        setCollision(player.Character, true)
        for _, conn in ipairs(connections) do
            if conn and conn.Connected then
                conn:Disconnect()
            end
        end
        sg:Destroy()
    end)

    connect(miniBtn.MouseButton1Click, function()
        is_minimized = not is_minimized
        main:TweenSize(
            is_minimized and UDim2.new(0, 600, 0, 50) or UDim2.new(0, 600, 0, 500),
            "Out", "Quad", 0.3, true
        )
    end)

    connect(UserInputService.InputBegan, function(i, p)
        if not p then
            if i.KeyCode == key_farm then 
                if selected_boss_data and boss_farming_enabled then
                    toggleBossFarm()
                elseif selected_mob_data and farming_enabled then
                    toggleSpecificFarm()
                else
                    toggleSpecificFarm()
                end
            elseif i.KeyCode == key_nearest then toggleNearestFarm()
            elseif i.KeyCode == key_infinite_tower then toggleInfiniteTowerFarm()
            elseif i.KeyCode == key_click then autoclick_enabled = not autoclick_enabled
            elseif i.KeyCode == key_abilities then auto_abilities_enabled = not auto_abilities_enabled
            elseif i.KeyCode == ui_toggle_key then main.Visible = not main.Visible end
        end
    end)

    -- Auto Equip al respawnear
    connect(player.CharacterAdded, function(char)
        if not auto_equip_enabled then return end
        task.spawn(function()
            local humanoid = char:WaitForChild("Humanoid", 3)
            if not humanoid then return end
            
            -- Esperar a que backpack tenga tools (reintentos)
            local attempts = 0
            while attempts < 15 do
                local backpack = player:FindFirstChild("Backpack")
                if backpack then
                    local toolCount = 0
                    for _, v in ipairs(backpack:GetChildren()) do
                        if v:IsA("Tool") then toolCount += 1 end
                    end
                    if toolCount >= auto_equip_slot then
                        tryEquipSlot()
                        break
                    end
                end
                attempts += 1
                task.wait(0.3)
            end
        end)
    end)

    -- Loop ligero: solo si no tiene nada en mano
    task.spawn(function()
        while is_script_active do
            if auto_equip_enabled then
                local char = player.Character
                if char and not char:FindFirstChildOfClass("Tool") then
                    tryEquipSlot()
                end
            end
            task.wait(2.5)
        end
    end)

    -- ================= LOOPS SECUNDARIOS =================
    task.spawn(function()
        while is_script_active do
            if autoclick_enabled then
                pcall(function()
                    VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
                    task.wait(0.01)
                    VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
                end)
            end
            if auto_abilities_enabled then
                for _, k in ipairs({Enum.KeyCode.Z, Enum.KeyCode.X, Enum.KeyCode.C, Enum.KeyCode.G}) do
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(true, k, false, game)
                        task.wait(0.05)
                        VirtualInputManager:SendKeyEvent(false, k, false, game)
                    end)
                end
            end
            task.wait(0.1)
        end
    end)

    task.spawn(function()
        local vu = game:GetService("VirtualUser")
        connect(player.Idled, function()
            vu:CaptureController()
            vu:ClickButton2(Vector2.new())
        end)
    end)
