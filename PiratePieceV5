-- ================= FUNCIONES UTILITARIAS =================
local function setCollision(char, state)
    if not char then return end
    for _, p in pairs(char:GetChildren()) do
        if p:IsA("BasePart") then
            p.CanCollide = state
        end
    end
end

local function getSafePosition()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local rayOrigin = hrp.Position
        local rayDirection = Vector3.new(0, -100, 0)
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {char}
        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        local result = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
        if result then
            return result.Position + Vector3.new(0, 5, 0)
        end
    end
    if selected_mob_data then
        return selected_mob_data.Spawn + Vector3.new(0, 10, 0)
    end
    if selected_boss_data then
        return selected_boss_data.Spawn + Vector3.new(0, 10, 0)
    end
    return Vector3.new(437.667, 10, 54.448)
end

local function dropNextToEnemy()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    setCollision(char, true)
    if hrp and target_part and target_part.Parent then
        local mobH = target_part.Parent:FindFirstChildOfClass("Humanoid")
        if mobH and mobH.Health > 0 then
            hrp.Velocity = Vector3.zero
            hrp.CFrame = target_part.CFrame * CFrame.new(0, 2, 4)
            return
        end
    end
    if hrp then
        hrp.Velocity = Vector3.zero
        local safePos = getSafePosition()
        hrp.CFrame = CFrame.new(safePos)
    end
    target_part = nil
    boss_target_part = nil
end

-- ================= AUTO EQUIP FIX =================
local function tryEquipSlot()
    if not auto_equip_enabled or equipDebounce then return end
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    -- Si ya tiene algo equipado, no tocar nada
    if char:FindFirstChildOfClass("Tool") then return end

    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return end

    local tools = {}
    for _, v in ipairs(backpack:GetChildren()) do
        if v:IsA("Tool") then
            table.insert(tools, v)
        end
    end

    local targetTool = tools[auto_equip_slot]
    if not targetTool then return end

    equipDebounce = true
    pcall(function()
        humanoid:EquipTool(targetTool)
    end)
    task.wait(1.0)
    equipDebounce = false
end


-- ================= INFINITE TOWER FUNCS =================
local function getInfiniteTowerEnemies()
    local enemies = {}
    local towerFolder = Workspace:FindFirstChild("Infinite Tower")
    if not towerFolder then return enemies end
    local runtimeEnemies = towerFolder:FindFirstChild("RuntimeEnemies")
    if not runtimeEnemies then return enemies end

    for _, model in ipairs(runtimeEnemies:GetChildren()) do
        if model:IsA("Model") then
            local hum = model:FindFirstChildOfClass("Humanoid")
            local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChildWhichIsA("BasePart")
            if hum and hum.Health > 0 and hrp then
                table.insert(enemies, {
                    Name = model.Name,
                    Model = model,
                    HRP = hrp,
                    Humanoid = hum
                })
            end
        end
    end
    return enemies
end

local function toggleInfiniteTowerFarm()
    infinite_tower_enabled = not infinite_tower_enabled
    if farming_enabled and infinite_tower_enabled then farming_enabled = false end
    if nearest_farming_enabled and infinite_tower_enabled then nearest_farming_enabled = false end
    if boss_farming_enabled and infinite_tower_enabled then boss_farming_enabled = false end

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if infinite_tower_enabled and hrp then
        lastSafePosition = hrp.Position
    elseif not infinite_tower_enabled then
        dropNextToEnemy()
    end
end

